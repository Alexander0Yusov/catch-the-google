{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmitOnError": false,
    "allowJs": false,
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "back/**/*.ts",
    "domain/**/*.ts",
    "observer/**/*.ts",
    "front.ts",
    "game.ts",
    "game-remote-proxy.ts"
  ],
  "exclude": ["node_modules", "dist", "tests", "vitest.config.ts"]
}
