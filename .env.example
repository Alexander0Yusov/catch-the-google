# Локальный запуск
PORT=3001

# Neon PostgreSQL
# Рекомендуемый вариант: одной строкой
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Альтернативный вариант: отдельными переменными
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Для Neon обычно нужен SSL
DB_SSL=enable

# Важно: по умолчанию миграции отключены,
# чтобы не менять существующие таблицы в БД
AUTO_RUN_MIGRATIONS=false
