{
  "name": "catch-the-google",
  "version": "1.0.0",
  "description": "Мультиплеерная игра Catch The Google (WebSocket + Node.js + TypeScript)",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nest build",
    "build:ts": "tsc",
    "start:nest": "node dist/main.js",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "start:back": "node dist/main.js",
    "start:front": "serve . -l 3000",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check:migrations": "node ./scripts/check-migrations.mjs",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test"
  },
  "keywords": [
    "websocket",
    "game",
    "nodejs",
    "portfolio",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.16",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/platform-socket.io": "^11.1.16",
    "@nestjs/websockets": "^11.1.16",
    "joi": "^18.0.2",
    "pg": "^8.19.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "serve": "^14.2.6",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "eslint-plugin-import": "^2.32.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
